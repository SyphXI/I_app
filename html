#!/usr/bin/env python3
"""
Appspace API Python Tool
========================
A command-line tool to interact with the Appspace API v3.

Usage:
    python appspace_tool.py --url <appspace_url> --subject-id <id> --refresh-token <token> <command>

Commands:
    auth            Get a new access token
    channels        List all channels
    channel-get     Get a specific channel by ID
    channel-create  Create a new channel
    users           List all users
    user-get        Get a specific user by ID
    devices         List all devices
    device-get      Get a specific device by ID
    library         List library contents
    spaces          List space reservations
    feeds           List feeds

Requirements:
    pip install requests

"""

import argparse
import json
import sys
import os
import time
from datetime import datetime

try:
    import requests
except ImportError:
    print("ERROR: 'requests' library not found. Install it with: pip install requests")
    sys.exit(1)


# ─────────────────────────────────────────────
# Appspace API Client
# ─────────────────────────────────────────────

class AppspaceClient:
    def __init__(self, base_url: str, subject_id: str = None, refresh_token: str = None, api_key: str = None):
        self.base_url = base_url.rstrip("/")
        self.subject_id = subject_id
        self.refresh_token = refresh_token
        self.api_key = api_key
        self.access_token = None
        self.token_expires_at = 0

    # ── Authentication ──────────────────────────────────────────────────

    def get_access_token(self) -> str:
        """Fetch a fresh access token using subject_id + refresh_token."""
        url = f"{self.base_url}/api/v3/authorization/token"
        payload = {
            "subjectType": "Application",
            "subjectId": self.subject_id,
            "grantType": "refreshToken",
            "refreshToken": self.refresh_token,
        }
        resp = requests.post(url, json=payload, timeout=15)
        resp.raise_for_status()
        data = resp.json()
        self.access_token = data["accessToken"]
        self.refresh_token = data.get("refreshToken", self.refresh_token)
        # expiresIn is in seconds; store absolute expiry time
        expires_in = int(data.get("expiresIn", 3600))
        self.token_expires_at = time.time() + expires_in - 60  # 60s buffer
        return self.access_token

    def _ensure_token(self):
        """Auto-refresh token if expired or missing."""
        if self.api_key:
            return  # API key mode — no token needed
        if not self.access_token or time.time() >= self.token_expires_at:
            self.get_access_token()

    def _headers(self) -> dict:
        self._ensure_token()
        if self.api_key:
            return {"Content-Type": "application/json", "X-API-Key": self.api_key}
        return {"Content-Type": "application/json", "Authorization": f"Bearer {self.access_token}"}

    def _get(self, path: str, params: dict = None) -> dict:
        url = f"{self.base_url}/api/v3/{path.lstrip('/')}"
        resp = requests.get(url, headers=self._headers(), params=params, timeout=15)
        resp.raise_for_status()
        return resp.json()

    def _post(self, path: str, payload: dict) -> dict:
        url = f"{self.base_url}/api/v3/{path.lstrip('/')}"
        resp = requests.post(url, headers=self._headers(), json=payload, timeout=15)
        resp.raise_for_status()
        return resp.json()

    def _put(self, path: str, payload: dict) -> dict:
        url = f"{self.base_url}/api/v3/{path.lstrip('/')}"
        resp = requests.put(url, headers=self._headers(), json=payload, timeout=15)
        resp.raise_for_status()
        return resp.json()

    def _delete(self, path: str) -> dict:
        url = f"{self.base_url}/api/v3/{path.lstrip('/')}"
        resp = requests.delete(url, headers=self._headers(), timeout=15)
        resp.raise_for_status()
        return resp.json() if resp.content else {"status": "deleted"}

    # ── Channels ────────────────────────────────────────────────────────

    def list_channels(self, limit: int = 20, offset: int = 0) -> dict:
        """List channels in the channel directory."""
        return self._get("channelDirectory", params={"limit": limit, "offset": offset})

    def get_channel(self, channel_id: str) -> dict:
        """Get a specific channel by ID."""
        return self._get(f"channelDirectory/{channel_id}")

    def create_channel(self, name: str, channel_type: str = "playlist", network_id: str = None) -> dict:
        """Create a new channel."""
        payload = {"name": name, "type": channel_type}
        if network_id:
            payload["networkId"] = network_id
        return self._post("channels", payload)

    def publish_channel(self, channel_id: str, device_ids: list = None, user_ids: list = None) -> dict:
        """Publish a channel to devices or users."""
        payload = {}
        if device_ids:
            payload["deviceIds"] = device_ids
        if user_ids:
            payload["userIds"] = user_ids
        return self._post(f"channels/{channel_id}/publish", payload)

    # ── Users ───────────────────────────────────────────────────────────

    def list_users(self, limit: int = 20, offset: int = 0) -> dict:
        """List users in the account."""
        return self._get("users", params={"limit": limit, "offset": offset})

    def get_user(self, user_id: str) -> dict:
        """Get a specific user by ID."""
        return self._get(f"users/{user_id}")

    def invite_user(self, email: str, role: str = "viewer") -> dict:
        """Invite a new user by email."""
        return self._post("users/invite", {"email": email, "role": role})

    # ── Devices ─────────────────────────────────────────────────────────

    def list_devices(self, limit: int = 20, offset: int = 0) -> dict:
        """List registered devices."""
        return self._get("devices", params={"limit": limit, "offset": offset})

    def get_device(self, device_id: str) -> dict:
        """Get a specific device by ID."""
        return self._get(f"devices/{device_id}")

    def assign_channel_to_device(self, device_id: str, channel_id: str) -> dict:
        """Assign a channel to a device."""
        return self._put(f"devices/{device_id}/channel", {"channelId": channel_id})

    # ── Library ─────────────────────────────────────────────────────────

    def list_library(self, limit: int = 20, offset: int = 0) -> dict:
        """List library contents."""
        return self._get("library/contents", params={"limit": limit, "offset": offset})

    def get_library_item(self, item_id: str) -> dict:
        """Get a specific library item."""
        return self._get(f"library/contents/{item_id}")

    # ── Spaces (Space Reservation) ───────────────────────────────────────

    def list_spaces(self, limit: int = 20) -> dict:
        """List available spaces/rooms."""
        return self._get("spaces", params={"limit": limit})

    def list_bookings(self, space_id: str = None) -> dict:
        """List space bookings, optionally filtered by space ID."""
        path = f"spaces/{space_id}/bookings" if space_id else "bookings"
        return self._get(path)

    # ── Feeds ────────────────────────────────────────────────────────────

    def list_feeds(self, limit: int = 20) -> dict:
        """List data feeds."""
        return self._get("feeds", params={"limit": limit})

    def get_feed(self, feed_id: str) -> dict:
        """Get a specific feed by ID."""
        return self._get(f"feeds/{feed_id}")

    # ── Networks ─────────────────────────────────────────────────────────

    def list_networks(self) -> dict:
        """List networks in the account."""
        return self._get("networks")


# ─────────────────────────────────────────────
# Pretty Printer
# ─────────────────────────────────────────────

def pretty(data: dict):
    print(json.dumps(data, indent=2))


def print_table(items: list, fields: list):
    """Simple tabular output for lists."""
    if not items:
        print("  (no results)")
        return
    # Calculate column widths
    widths = {f: len(f) for f in fields}
    for item in items:
        for f in fields:
            val = str(item.get(f, ""))
            widths[f] = max(widths[f], min(len(val), 50))
    # Header
    header = "  ".join(f.upper().ljust(widths[f]) for f in fields)
    print(header)
    print("-" * len(header))
    # Rows
    for item in items:
        row = "  ".join(str(item.get(f, "")).ljust(widths[f])[:widths[f]] for f in fields)
        print(row)


# ─────────────────────────────────────────────
# CLI
# ─────────────────────────────────────────────

def build_parser():
    parser = argparse.ArgumentParser(
        description="Appspace API v3 Python Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
EXAMPLES:
  # Authenticate and get a token
  python appspace_tool.py --url https://app9.cloud.appspace.com \\
      --subject-id YOUR_SUBJECT_ID --refresh-token YOUR_REFRESH_TOKEN auth

  # List channels (table view)
  python appspace_tool.py [auth args] channels

  # List channels (raw JSON)
  python appspace_tool.py [auth args] channels --json

  # Get a specific channel
  python appspace_tool.py [auth args] channel-get --id CHANNEL_ID

  # Create a channel
  python appspace_tool.py [auth args] channel-create --name "My Channel"

  # List users
  python appspace_tool.py [auth args] users

  # List devices
  python appspace_tool.py [auth args] devices

  # Assign a channel to a device
  python appspace_tool.py [auth args] device-assign --device-id DEV_ID --channel-id CH_ID

  # List library contents
  python appspace_tool.py [auth args] library

  # List available spaces
  python appspace_tool.py [auth args] spaces
        """
    )

    # Connection args
    conn = parser.add_argument_group("Connection")
    conn.add_argument("--url", required=True, help="Appspace base URL, e.g. https://app9.cloud.appspace.com")
    auth_group = conn.add_mutually_exclusive_group()
    auth_group.add_argument("--subject-id", help="Application integration subject ID (use with --refresh-token)")
    conn.add_argument("--refresh-token", help="Refresh token for the application integration")
    auth_group.add_argument("--api-key", help="API key (alternative to subject-id + refresh-token)")

    # Output
    parser.add_argument("--json", action="store_true", help="Output raw JSON instead of table")
    parser.add_argument("--limit", type=int, default=20, help="Max results to return (default: 20)")
    parser.add_argument("--offset", type=int, default=0, help="Results offset for pagination (default: 0)")

    # Commands
    subs = parser.add_subparsers(dest="command", title="Commands")
    subs.required = True

    # auth
    subs.add_parser("auth", help="Fetch and display a new access token")

    # channels
    subs.add_parser("channels", help="List all channels")

    ch_get = subs.add_parser("channel-get", help="Get a channel by ID")
    ch_get.add_argument("--id", required=True, help="Channel ID")

    ch_create = subs.add_parser("channel-create", help="Create a new channel")
    ch_create.add_argument("--name", required=True, help="Channel name")
    ch_create.add_argument("--type", default="playlist", choices=["playlist", "live", "advanced"], help="Channel type")
    ch_create.add_argument("--network-id", help="Network ID to assign channel to")

    ch_pub = subs.add_parser("channel-publish", help="Publish a channel to devices/users")
    ch_pub.add_argument("--id", required=True, help="Channel ID")
    ch_pub.add_argument("--device-ids", nargs="+", help="Device IDs to publish to")
    ch_pub.add_argument("--user-ids", nargs="+", help="User IDs to publish to")

    # users
    subs.add_parser("users", help="List users")

    u_get = subs.add_parser("user-get", help="Get a user by ID")
    u_get.add_argument("--id", required=True, help="User ID")

    u_invite = subs.add_parser("user-invite", help="Invite a user by email")
    u_invite.add_argument("--email", required=True, help="User email address")
    u_invite.add_argument("--role", default="viewer", help="User role (default: viewer)")

    # devices
    subs.add_parser("devices", help="List registered devices")

    d_get = subs.add_parser("device-get", help="Get a device by ID")
    d_get.add_argument("--id", required=True, help="Device ID")

    d_assign = subs.add_parser("device-assign", help="Assign a channel to a device")
    d_assign.add_argument("--device-id", required=True, help="Device ID")
    d_assign.add_argument("--channel-id", required=True, help="Channel ID to assign")

    # library
    subs.add_parser("library", help="List library contents")

    lib_get = subs.add_parser("library-get", help="Get a library item by ID")
    lib_get.add_argument("--id", required=True, help="Library item ID")

    # spaces
    subs.add_parser("spaces", help="List spaces/rooms")

    bookings = subs.add_parser("bookings", help="List bookings")
    bookings.add_argument("--space-id", help="Filter by space ID")

    # feeds
    subs.add_parser("feeds", help="List data feeds")

    f_get = subs.add_parser("feed-get", help="Get a feed by ID")
    f_get.add_argument("--id", required=True, help="Feed ID")

    # networks
    subs.add_parser("networks", help="List networks")

    return parser


def run(args):
    # Validate auth args
    if not args.api_key and (not args.subject_id or not args.refresh_token):
        print("ERROR: Provide either --api-key OR both --subject-id and --refresh-token")
        sys.exit(1)

    client = AppspaceClient(
        base_url=args.url,
        subject_id=getattr(args, "subject_id", None),
        refresh_token=getattr(args, "refresh_token", None),
        api_key=getattr(args, "api_key", None),
    )

    cmd = args.command

    try:
        # ── AUTH ──
        if cmd == "auth":
            token = client.get_access_token()
            exp = datetime.fromtimestamp(client.token_expires_at + 60).strftime("%Y-%m-%d %H:%M:%S")
            print(f"✅ Token obtained successfully (expires ~{exp})")
            if args.json:
                print(json.dumps({"accessToken": token, "expiresAt": exp}, indent=2))
            return

        # ── CHANNELS ──
        elif cmd == "channels":
            data = client.list_channels(args.limit, args.offset)
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n📺 Channels ({len(items)} results)\n")
                print_table(items, ["id", "name", "type", "status"])

        elif cmd == "channel-get":
            pretty(client.get_channel(args.id))

        elif cmd == "channel-create":
            result = client.create_channel(args.name, args.type, getattr(args, "network_id", None))
            print(f"✅ Channel created:")
            pretty(result)

        elif cmd == "channel-publish":
            result = client.publish_channel(args.id, getattr(args, "device_ids", None), getattr(args, "user_ids", None))
            print(f"✅ Published:")
            pretty(result)

        # ── USERS ──
        elif cmd == "users":
            data = client.list_users(args.limit, args.offset)
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n👥 Users ({len(items)} results)\n")
                print_table(items, ["id", "email", "firstName", "lastName", "role"])

        elif cmd == "user-get":
            pretty(client.get_user(args.id))

        elif cmd == "user-invite":
            result = client.invite_user(args.email, args.role)
            print(f"✅ Invite sent:")
            pretty(result)

        # ── DEVICES ──
        elif cmd == "devices":
            data = client.list_devices(args.limit, args.offset)
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n📱 Devices ({len(items)} results)\n")
                print_table(items, ["id", "name", "type", "status", "networkId"])

        elif cmd == "device-get":
            pretty(client.get_device(args.id))

        elif cmd == "device-assign":
            result = client.assign_channel_to_device(args.device_id, args.channel_id)
            print(f"✅ Channel assigned:")
            pretty(result)

        # ── LIBRARY ──
        elif cmd == "library":
            data = client.list_library(args.limit, args.offset)
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n📁 Library ({len(items)} results)\n")
                print_table(items, ["id", "name", "type", "size", "createdAt"])

        elif cmd == "library-get":
            pretty(client.get_library_item(args.id))

        # ── SPACES ──
        elif cmd == "spaces":
            data = client.list_spaces(args.limit)
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n🏢 Spaces ({len(items)} results)\n")
                print_table(items, ["id", "name", "type", "capacity", "networkId"])

        elif cmd == "bookings":
            data = client.list_bookings(getattr(args, "space_id", None))
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n📅 Bookings ({len(items)} results)\n")
                print_table(items, ["id", "spaceId", "startTime", "endTime", "organizer"])

        # ── FEEDS ──
        elif cmd == "feeds":
            data = client.list_feeds(args.limit)
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n📡 Feeds ({len(items)} results)\n")
                print_table(items, ["id", "name", "type", "status"])

        elif cmd == "feed-get":
            pretty(client.get_feed(args.id))

        # ── NETWORKS ──
        elif cmd == "networks":
            data = client.list_networks()
            if args.json:
                pretty(data)
            else:
                items = data.get("data", data if isinstance(data, list) else [])
                print(f"\n🌐 Networks ({len(items)} results)\n")
                print_table(items, ["id", "name", "parentId"])

    except requests.exceptions.HTTPError as e:
        print(f"\n❌ HTTP Error {e.response.status_code}: {e.response.text}")
        sys.exit(1)
    except requests.exceptions.ConnectionError:
        print(f"\n❌ Connection error — check your --url: {args.url}")
        sys.exit(1)
    except Exception as e:
        print(f"\n❌ Error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    parser = build_parser()
    args = parser.parse_args()
    run(args)
